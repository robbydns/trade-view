# Crypto Signal Compass - Binance real-time only
PORT=4000
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/!ticker@arr
BINANCE_REST_URLS=https://data-api.binance.vision,https://api.binance.com,https://api1.binance.com,https://api2.binance.com,https://api3.binance.com
BINANCE_ANALYZED_PAIR_LIMIT=100
BINANCE_CACHE_MS=20000
BINANCE_FUTURES_URL=https://fapi.binance.com
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Dashboard login
AUTH_EMAIL=your-dashboard-email
AUTH_PASSWORD=use-a-strong-password
AUTH_SECRET=generate-a-long-random-secret

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_ALERT_ENABLED=false
